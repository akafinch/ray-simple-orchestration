# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

linode_token = "your-linode-api-token-here"

# Required — set these for your deployment:
region             = "in-bom-2"
obj_storage_region = "in-maa-1"
allowed_ips        = [
  "24.115.103.113/32",
  "70.170.50.50/32",
  "170.203.114.78/32",
  "193.43.135.45/32",
  "172.238.57.42/32"
]

# LKE tier: "enterprise" (VPC-only, auto-firewall) or "standard"
# lke_tier           = "enterprise"

# Optional overrides (defaults shown):
# cluster_label      = "clip-clap-inference"
# k8s_version        = "1.35"
# cpu_node_type      = "g6-standard-4"
# cpu_node_count     = 2
# gpu_node_type      = "g2-gpu-rtx4000a1-s"
# gpu_node_count     = 3
# model_bucket_label = "clip-clap-weights"
